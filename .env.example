# SOLANA_RPC_BACKOFF_BASE_MS=400
# SOLANA_GAS_MONITOR_INTERVAL_SECONDS=60
# SOLANA_GAS_LOW_THRESHOLD_LAMPORTS=200000000
# Sui slash path:
# - SUI_SLASH_MODE=direct : backend executes `sui client call` directly (Phase 42)
# - SUI_SLASH_MODE=http   : backend calls SUI_SLASH_RELAYER_URL
