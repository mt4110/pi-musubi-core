# SOLANA_RELAYER_MODE=anchor
# SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_RELAYER_SECRET_BASE58=
# SOLANA_CHIGIRI_PROGRAM_ID=
# SOLANA_TOKEN_PROGRAM_ID=TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA
# SOLANA_EXPLORER_BASE_URL=https://solscan.io/tx
